    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.45.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "babel-jest": "^30.4.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.6",
    "jest": "^29.7.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0",
    "yaml": "^2.9.0"
  },
  "dependencies": {
    "@tabler/icons-webfont": "^3.44.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.17.0",
    "recharts": "^2.15.4"
  },
  "scripts": {
    "start": "vite",
    "build": "npm run lint && vite build && npm run test:ci",
    "build:app": "vite build",
    "lint": "eslint src foundry-bridge --max-warnings 0",
    "test": "vitest",
    "test:ci": "npm run lint && vitest run --coverage --passWithNoTests",
    "test:unit:ci": "vitest run --coverage --passWithNoTests",
    "test:bridge": "jest --config foundry-bridge/jest.config.js",
    "test:bridge:ci": "jest --config foundry-bridge/jest.config.js --ci --coverage",
    "test:e2e": "playwright test",
    "test:e2e:local": "playwright test",
    "snapshot:content": "node scripts/snapshotContent.js",
    "lore:export": "node scripts/exportLoreVault.js",
    "lore:push": "node scripts/pushLoreVault.js"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
